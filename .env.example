# Frontend Environment Variables
# Copy this file to .env.local and update values for your environment

# API URL for the FastAPI backend
# IMPORTANT: The frontend will call ${NEXT_PUBLIC_API_URL}/assess endpoint
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (Render):
# NEXT_PUBLIC_API_URL=https://your-render-backend-url.onrender.com
# Note: Backend must have CORS enabled to allow requests from your frontend domain

# Optional: Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=false
